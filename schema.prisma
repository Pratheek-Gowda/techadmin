generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://neondb_owner:npg_nbV8WuMXmeK6@ep-old-tooth-amz23ta1-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  balance   Float    @default(0)
  role      String   @default("user") // "admin" or "user"
  requests  FundRequest[]
}

model Transaction {
  id          String   @id @default(uuid())
  type        String   // "credit", "debit", "admin_add", "admin_remove"
  amount      Float
  description String
  entity      String   // "user" or "admin"
  userId      String?
  createdAt   DateTime @default(now())
}

model FundRequest {
  id        String   @id @default(uuid())
  amount    Float
  status    String   @default("pending") // "pending", "approved", "rejected"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model GlobalSettings {
  id           Int    @id @default(1)
  adminWallet  Float  @default(0)
  notification String @default("Welcome to Pratheek Enterprises")
  contactPhone String @default("+91 9164132150")
  contactEmail String @default("pratheek@myyahoo.com")
}
