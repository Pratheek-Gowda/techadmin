generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

model User {
id        String   @id @default(uuid())
username  String   @unique
password  String
balance   Float    @default(0)
role      String   @default("user") // "admin" or "user"

// Relations
requests  FundRequest[]
}

model Transaction {
id          String   @id @default(uuid())
type        String   // "credit", "debit", "admin_add", "admin_remove"
amount      Float
description String
entity      String   // "user" or "admin"
userId      String?  // Optional: linked to user for user-specific logs
createdAt   DateTime @default(now())
}

model FundRequest {
id        String   @id @default(uuid())
amount    Float
status    String   @default("pending") // "pending", "approved", "rejected"
createdAt DateTime @default(now())

// Relations
user      User     @relation(fields: [userId], references: [id])
userId    String
}

model GlobalSettings {
id           Int    @id @default(1)
adminWallet  Float  @default(0)
notification String @default("Welcome to Pratheek Enterprises")
contactPhone String @default("+91 0000000000")
contactEmail String @default("admin@pratheek.tech")
}
